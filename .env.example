# =============================================================================
# RIO Protocol — Environment Configuration
# =============================================================================
# Copy this file to .env and edit values as needed:
#   cp .env.example .env
#
# All paths are relative to the project root unless absolute.
# =============================================================================

# --- Environment ---
RIO_ENV=local

# --- Data Directories ---
RIO_DATA_DIR=runtime/data
RIO_LEDGER_FILE=runtime/data/ledger.jsonl
RIO_CORPUS_FILE=runtime/data/governed_corpus.jsonl

# --- Cryptographic Keys ---
RIO_KEYS_DIR=runtime/keys

# --- Execution Mode ---
# "simulated" — connectors and adapters log but do not perform real actions
# "live"      — connectors and adapters execute against real systems
RIO_MODE=simulated

# --- Admin Bootstrap ---
ADMIN_EMAIL=admin@rio.local
ADMIN_PASSWORD=change_me

# --- Server ---
RIO_API_HOST=0.0.0.0
RIO_API_PORT=8000
RIO_DASHBOARD_HOST=0.0.0.0
RIO_DASHBOARD_PORT=8050

# --- Logging ---
RIO_LOG_LEVEL=INFO
